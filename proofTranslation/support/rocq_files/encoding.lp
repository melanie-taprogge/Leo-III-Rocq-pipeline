// DK/Lambdapi symbols used for encoding simple type theory.

builtin "El" ≔ {|τ|};
builtin "Prf" ≔ {|π|};

// Symbols with special Rocq notation.
builtin "Set" ≔ Set;
builtin "prop" ≔ Prop;
builtin "arr" ≔ {|⤳|};
builtin "imp" ≔ {|⇒|};
builtin "all" ≔ {|∀|};
builtin "eq" ≔ {|=|};
builtin "or" ≔ {|∨|};
builtin "and" ≔ {|∧|};
builtin "ex" ≔ {|∃|};
builtin "not" ≔ {|¬|};
